---
import "../styles/global.css";
import {Image } from "astro:assets";
import Logo from "../assets/logo-yea.svg"
---
<!--used solely for login/register page-->
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width"/>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
        <meta name="generator" content={Astro.generator}/>
        <title>Actual Intelligence</title>
    </head>
    <body>
        <main class="flex min-h-screen w-full flex-col justify-center items-center gap-8 p-4">
            <Image src={Logo} alt="Actual Intelligence Logo" class="w-32 h-32"/>
            <h1 class="text-5xl font-bold text-center">Actual Intelligence</h1>
            <div class="w-full max-w-sm mx-auto">
                <slot/>
            </div>
        </main>
    </body>
</html>
